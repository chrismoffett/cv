GDRIVE_CLIENT_ID=        # Google OAuth client ID
GDRIVE_CLIENT_SECRET=    # Google OAuth client secret
GDRIVE_REFRESH_TOKEN=    # Google OAuth refresh token (must include both drive AND gmail.readonly scopes)
NOTION_API_KEY=          # Notion integration token (must be shared with the Projects database)
GITHUB_TOKEN=            # GitHub personal access token (repo scope) — required by spec, but cv_suggest.py uses `gh` CLI auth

# Optional:
# NOTION_PROJECTS_DB_ID= # Override database search if you have multiple databases named "Projects"
